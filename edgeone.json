{
  "installCommand": "npm --prefix frontend ci",
  "buildCommand": "node scripts/build-edgeone.mjs",
  "outputDirectory": "frontend/dist",
  "nodeVersion": "22.11.0",
  "cloudFunctions": {
    "python": {
      "maxDuration": 120
    },
    "mainlandRegions": ["ap-shanghai"],
    "overseasRegions": ["ap-hongkong"]
  },
  "headers": [
    {
      "source": "/assets/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
